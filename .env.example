# =============================================
#  TELEGRAM API (получи на https://my.telegram.org)
# =============================================
API_ID=12345678
API_HASH=your_api_hash_here
PHONE_NUMBER=+79991234567

# =============================================
#  xAI GROK API
# =============================================
GROK_API_KEY=xai-your-grok-api-key-here
GROK_MODEL=grok-4-1-fast-reasoning
GROK_BASE_URL=https://api.x.ai/v1

# =============================================
#  АГЕНТ — ЛИЧНОСТЬ И ЦЕЛЬ
# =============================================
AGENT_NAME=Алина
AGENT_PERSONA="Дизайнер интерьеров из Москвы. 5 лет опыта. Увлекаюсь скандинавским стилем и минимализмом. Работаю с клиентами онлайн и офлайн."
CONVERSION_GOAL="Порекомендовать курс по дизайну интерьера на платформе XYZ и дать ссылку"

# =============================================
#  ТРИГГЕР-СЛОВА (через запятую)
# =============================================
TRIGGER_WORDS=дизайн,интерьер,ремонт,обстановка,квартира

# =============================================
#  БЕЗОПАСНОСТЬ СЕССИИ
# =============================================
# Fernet ключ для шифрования StringSession (генерируется при onboarding)
SESSION_FERNET_KEY=

# =============================================
#  DATABASE
# =============================================
DB_PATH=data/agent.db

# =============================================
#  JOBS
# =============================================
CLEANUP_OLDER_THAN_DAYS=30
REPORT_INTERVAL_HOURS=24
# Telegram user_id куда слать отчёты (ваш личный аккаунт)
REPORT_RECIPIENT_ID=
